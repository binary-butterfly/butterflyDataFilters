{
  "name": "butterfly-data-filters",
  "version": "1.0.0-rc1",
  "license": "MIT",
  "private": false,
  "main": "dist/butterflyDataFilters.js",
  "module": "dist/index.mjs",
  "types": "dist/filterHelper.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/butterflyDataFilters.js"
    }
  },
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/binary-butterfly/butterflyDataFilters.git"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "prepublishOnly": "NODE_ENV=production vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@binary-butterfly/eslint-config": "^1.0.0-rc5",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.5"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all",
      "IE >= 11"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "bugs": {
    "url": "https://github.com/binary-butterfly/butterflyDataFilters/issues"
  },
  "homepage": "https://github.com/binary-butterfly/butterflyDataFilters#readme",
  "description": "A simple library for filtering data in JavaScript",
  "keywords": [
    "data",
    "filters"
  ],
  "author": "binary butterfly GmbH"
}
