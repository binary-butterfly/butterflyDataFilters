{
  "compilerOptions": {
    "lib": ["ESNext", "dom"],
    "allowJs": true,
    "target": "esnext",
    "allowSyntheticDefaultImports": true,
    "rootDir": "./",
    "sourceMap": true,
    "outDir": "dist",
    "noEmit": true,
    "strict": true,
    "noImplicitReturns": true,
    "moduleResolution": "nodenext",
    "module": "nodenext",
    "skipLibCheck": true,
    "declaration": false
  },
  "include": [
    "./src/**/*"
  ]
}
